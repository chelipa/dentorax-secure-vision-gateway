# Dentorax Secure Vision Gateway v0.1
# Copy to .env locally or set these as Railway/Render service variables.

PORT=8080
NODE_ENV=production

# Security
# For first test you can use *, but for real demo set your frontend URL only:
# ALLOWED_ORIGINS=https://app.dentorax.com,https://your-vercel-app.vercel.app
ALLOWED_ORIGINS=*
DENTORAX_ADMIN_TOKEN=

# Gateway identity
DENTORAX_GATEWAY_REGION=foreign-hosted
RETENTION_MODE=stateless_no_raw_image_storage

# Request limits
REQUEST_TIMEOUT_MS=90000
MAX_JSON_BODY=18mb
MAX_INLINE_IMAGE_BYTES=9000000

# Engine routing
ENGINE_PRIMARY=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_API_MODE=interactions
# If image route fails under interactions, try:
# GEMINI_API_MODE=generate_content
